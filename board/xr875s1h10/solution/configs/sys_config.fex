;boot0 debug_mode
;when debug_mode is 0, boot0 doesn't print debug message, otherwise print debug message
[platform]
debug_mode = 1

;boot0 use. PA4 and PA6 test on ver board is ok
[uart_para]
uart_debug_port = 0
uart_debug_tx   = port:PA9<2><1><default><default>
uart_debug_rx   = port:PA8<2><1><default><default>
;uart_debug_tx   = port:PB0<3><1><default><default>
;uart_debug_rx   = port:PB1<3><1><default><default>
;uart_debug_rx   = port:PA4<4><1><default><default>
;uart_debug_tx   = port:PA6<4><1><default><default>

[audio_hw_rv]
pcm_pb_rate 		= 48000
pcm_pb_channels 	= 2
pcm_pb_period_size  = 960
pcm_pb_periods  	= 8
pcm_pb_card  		= "hw:audiocodecdac"
;pcm_pb_card  		= "hw:snddaudio0"
pcm_pb_card_num  	= 0
pcm_pb_device_num  	= 0

pcm_cap_rate 		= 16000
pcm_cap_channels 	= 3
pcm_cap_card  		= "hw:audiocodecadc"
pcm_cap_card_num  	= 1
pcm_cap_device_num  = 0

[audio_hw_dsp]
pcm_cap_rate 		= 16000
pcm_cap_channels 	= 3
pcm_cap_bits  		= 16
pcm_cap_period_size  	= 320
pcm_cap_periods  	= 4
pcm_cap_silence_timems  = 300
pcm_cap_card  		= "hw:audiocodecadc"
pcm_cap_card_num  	= 0
pcm_cap_device_num  = 0

[gpio_irq_map]
gpio_1_1 = 0xAAAAAAAA
gpio_1_2 = 0xAAAAAAAA
gpio_2_1 = 0xAAAAAAAA
gpio_2_2 = 0xAAAAAAAA
gpio_3_1 = 0xAAAAAAAA
gpio_3_2 = 0xAAAAAAAA

[touchscreen]
tp_used                = 1
tp_driver_name         = "axs5106"
tp_int                 = port:PA10<14><1><default><default>
;tp_reset               = port:PB3<1><0><default><default>
;tp_revert_mode; 0: default; 1: revert x; 2: revery y
tp_revert_mode         = 0
;tp_exchange_flag; 0: default; 1:exchange x y
tp_exchange_flag       = 0
tp_max_x               = 320
tp_max_y               = 240
;tp_addr ;0x5D or 0x14
tp_addr                = 0x63
tp_twi_id              = 0

;----------------------------------------------------------------------------------
;wakeup-source configuration
;wakesrc name	= <val>
;val: Which processor is the wake source located on.
;	0x1 - ARM, 0x2 - DSP, 0x4 - RISCV
;----------------------------------------------------------------------------------
[wakeup-source]
lpuart		= 0x1
rtc_alarm	= 0x4
gpio		= 0x1
gpadc		= 0x4
mad-lpsd	= 0x2
btc_slptmr	= 0x1
wlan		= 0x1
wupio		= 0x4

;----------------------------------------------------------------------------------
;thermal configuration
;----------------------------------------------------------------------------------
[thermal]
critical_temperature = 105000

;----------------------------------------------------------------------------------
;aw9523 configuration gpio expansion
;----------------------------------------------------------------------------------
;[aw9523]
;aw9523_twi_id   = 1
