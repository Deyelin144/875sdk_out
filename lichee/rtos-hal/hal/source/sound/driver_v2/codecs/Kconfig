	  Select Y to add support the Codec embedded in the Allwinner
	  sun20iw2 and affiliated SoCs.

if SUNXI_SOUND_CODEC_SUN20IW2_AUDIOCODEC
menu "Allwinner AudioCodec V2 Choose"
config SUNXI_SOUND_CODEC_AUDIOCODEC_DAC
	bool "Allwinner AudioCodec DAC V2 Support"
	default n
	select SUNXI_SOUND_COMMON_SUNXI_COMMON
	select SUNXI_SOUND_COMMON_ALG_CFG
	help
	  Select Y to add support for audiocodec dac.

config SUNXI_SOUND_CODEC_AUDIOCODEC_ADC
	bool "Allwinner AudioCodec ADC V2 Support"
	default n
	select SUNXI_SOUND_COMMON_SUNXI_COMMON
	help
	  Select Y to add support for audiocodec adc.

config SUNXI_SOUND_CODEC_AUDIOCODEC_DAC_KEEP_AUDIO_PLL_ON
	bool "keep audio pll on"
	default n
	depends on SUNXI_SOUND_CODEC_AUDIOCODEC_DAC
	help
	  Select Y to keep audio pll on during standby.

endmenu
endif

config SUNXI_SOUND_CODEC_DUMMY
	bool "Sunxi dummy codec V2"
	default n

config SUNXI_SOUND_CODEC_AC108
	bool "Sunxi AC108 codec V2"
	default n

config SUNXI_SOUND_CODEC_AC101S
	bool "Sunxi AC101S codec V2"
	default n
	select DRIVERS_TWI

endmenu
