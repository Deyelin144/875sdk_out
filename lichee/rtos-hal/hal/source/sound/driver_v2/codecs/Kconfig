menu "AllWinner CODEC drivers V2"

config SUNXI_SOUND_CODEC_SUN8IW18_AUDIOCODEC
	bool "Allwinner AudioCodec support"
	default n
	select SUNXI_SOUND_PLATFORM_CPUDAI
	select SUNXI_SOUND_PLATFORM_PCM
	select SUNXI_SOUND_COMMON_SUNXI_COMMON
	depends on (ARCH_SUN8IW18P1 || ARCH_SUN8IW18)
	help
	  Select Y to add support the Codec embedded in the Allwinner
	  sun8iw18 and affiliated SoCs.

config SUNXI_SOUND_CODEC_SUN8IW19_AUDIOCODEC
	bool "Allwinner AudioCodec support"
	default n
	select SUNXI_SOUND_PLATFORM_CPUDAI
	select SUNXI_SOUND_PLATFORM_PCM
	select SUNXI_SOUND_COMMON_SUNXI_COMMON
	depends on (ARCH_SUN8IW19P1 || ARCH_SUN8IW19)
	help
	  Select Y to add support the Codec embedded in the Allwinner
	  sun8iw19 and affiliated SoCs.

config SUNXI_SOUND_CODEC_SUN8IW20_AUDIOCODEC
	bool "Allwinner AudioCodec V2 support"
	default n
	select SUNXI_SOUND_PLATFORM_CPUDAI
	select SUNXI_SOUND_PLATFORM_PCM
	select SUNXI_SOUND_COMMON_SUNXI_COMMON
	depends on (SOC_SUN20IW1P1 || ARCH_SUN8IW20)
	help
	  Select Y to add support the Codec embedded in the Allwinner
	  sun8iw20 and affiliated SoCs.

config SUNXI_SOUND_CODEC_SUN20IW2_AUDIOCODEC
	bool "Allwinner AudioCodec V2 support"
	default n
	select SUNXI_SOUND_PLATFORM_CPUDAI
	select SUNXI_SOUND_PLATFORM_PCM
	depends on (ARCH_SUN20IW2P1 || ARCH_SUN20IW2)
