menu "SPI Devices"

config DRIVERS_SPI
    bool "enable spi driver"
        default n

config DRIVERS_SPI_PANIC_TRANSFER
    bool "support sp transfer if crash"
    depends on DRIVERS_SPI
        default n

config DRIVERS_SPI_DMA_MALLOC_SELF
    bool "spi dma will malloc buff"
    depends on DRIVERS_SPI
        default y

config HAL_TEST_SPI
    bool "enable spi hal APIs test command"
    depends on DRIVERS_SPI
        default n

endmenu
