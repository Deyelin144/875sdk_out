menuconfig COMPONENT_FLAG
    bool "flag"
    select COMPONENTS_AW_BLKPART
    default n
    help
      support read write env
      If unsure, say Y.

if COMPONENT_FLAG

    config COMPONENTS_ENV_SIZE
    int "env Size (bytes)"
    default 4096
    help
        Size of env in bytes.

    config COMPONENTS_FLAG_PRINTENV
    bool "print env"
    default y
    help
        print env.

    config COMPONENTS_FLAG_SETENV
    bool "set env"
    default y
    help
        set env.

    config COMPONENTS_FLAG_FILE_SUPPORT
    bool "support file operations"
    default y
    help
        support standard open,read,write.

    config READ_ENV_IN_EARLY_STAGE
    bool "support read env in early stage"
	default n

endif
