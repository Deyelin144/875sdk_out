menu "aw multimedia"
config LIB_MULTIMEDIA
	bool "support cedarx player"
	default n

config LIB_RECORDER
	bool "support cedarx recorder"
	default n

config LIB_MULTIMEDIA_CROP
    bool "support cedarx customization"
    depends on (LIB_MULTIMEDIA || LIB_RECORDER)
    default n

menu "multimedia demo"
config RTPLAYER_TEST
#    select COMPONENTS_AW_ALSA_LIB
#    select COMPONENT_VFS
#    select COMPONENTS_TCPIP
    select COMPONENTS_LWIP
    select COMPONENTS_MBEDTLS
	select LIB_MULTIMEDIA
	depends on DRIVERS_SOUND || DRIVERS_SOUND_V2
	bool "test rtplayer demo"
    default n

config RTPLAYER_DIRPLAY
    bool "rtplayer support dirplay"
    default y
    depends on RTPLAYER_TEST

config TOTAL_AUDIO_NUM
    int "set max num of dir-play supporting"
    depends on RTPLAYER_DIRPLAY
    default 30

config RTRECORDER_TEST
    bool "test cedarx recorder demo"
	select LIB_RECORDER
	depends on DRIVERS_SOUND || DRIVERS_SOUND_V2
    default n

config RTOPUS_TEST
    bool "test opus encode and decode demo"
    default n

config PLAY_FIFO
	bool "rtos multimedia play fifo demo"
	select LIB_MULTIMEDIA
	depends on DRIVERS_SOUND || DRIVERS_SOUND_V2
	default n

config AVI_TEST
    bool "avi play test"
    default n

config MP4_TEST
    bool "mp4 play test"
    default n

config CUSTOMER_STREAM_TEST
    bool "customer stream test"
    default n

endmenu

endmenu
