menu "mem size"
	config MEM_SIZE
		int "MEM_SIZE: the size of the heap memory.(bytes)"
		default 32768
endmenu

menu "memp size"
	menu "socket"
		config MEMP_NUM_NETCONN
			int "MEMP_NUM_NETCONN: the number of struct netconns.(num of socket)"
			default 20
	endmenu
	menu "raw"
		config MEMP_NUM_RAW_PCB
			int "MEMP_NUM_RAW_PCB: Number of raw connection PCBs"
			default 2
	endmenu
	menu "udp"
		config MEMP_NUM_UDP_PCB
			int "MEMP_NUM_UDP_PCB: the number of udp protocol control blocks. one per active udp connection."
			default 10
	endmenu
	menu "tcp"
		config MEMP_NUM_TCP_PCB
			int "MEMP_NUM_TCP_PCB: the number of simultaneously active tcp connections."
			default 8
		config MEMP_NUM_TCP_SEG
			int "MEMP_NUM_TCP_SEG: the number of simultaneously queued tcp segments."
			default 48
	endmenu
	menu "arp"
		config MEMP_NUM_ARP_QUEUE
			int "MEMP_NUM_ARP_QUEUE: the number of simultaneously queued outgoing packets (pbufs)."
			default 16
	endmenu
	menu "dns"
		config MEMP_NUM_NETDB
			int "MEMP_NUM_NETDB: the number of concurrently running lwip_addrinfo() calls."
			default 1
	endmenu
	menu "input"
		config MEMP_NUM_TCPIP_MSG_INPKT
			int "MEMP_NUM_TCPIP_MSG_INPKT: the number of struct tcpip_msg, which are used for incoming packets."
			default 72
