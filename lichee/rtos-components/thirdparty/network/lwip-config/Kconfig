					bool "DNS_DEBUG: enable debugging for dns."
					default n
			endif
		endmenu
		menu "ip debug"
			if LWIP_IPV4
				config ETHARP_DEBUG
					bool "ETHARP_DEBUG: enable debugging in etharp.c."
					default n
				config ICMP_DEBUG
					bool "ICMP_DEBUG: enable debugging in icmp.c."
					default n
				config IP_DEBUG
					bool "IP_DEBUG: enable debugging for ip."
					default n
				config TCPIP_DEBUG
					bool "TCPIP_DEBUG: enable debugging in tcpip.c."
					default n
			endif
		endmenu
	endif
