menu "tcp"
	config LWIP_TCP
		bool "turn on tcp."
		default y
	if LWIP_TCP
		config DEFAULT_TCP_RECVMBOX_SIZE
			int "DEFAULT_TCP_RECVMBOX_SIZE: The mailbox size for the incoming packets on a NETCONN_TCP."
			default 40
		config TCP_WND
			int "TCP_WND: the size (bytes) of a tcp window.  at least (2 * tcp_mss)."
			default 20440
		config TCP_MAXRTX
			int "TCP_MAXRTX: maximum number of retransmissions of data segments."
			default 12
		config TCP_SYNMAXRTX
			int "TCP_SYNMAXRTX: maximum number of retransmissions of syn segments."
			default 6
		menuconfig LWIP_TCP_SACK_OUT
			bool "LWIP_TCP_SACK_OUT: tcp will support sending selective acknowledgements (sacks)"
			default n
			if LWIP_TCP_SACK_OUT
			config LWIP_TCP_MAX_SACK_NUM
				int "LWIP_TCP_MAX_SACK_NUM: the maximum number of sack values to include in tcp segments."
				default 4
			endif
		config TCP_MSS
			int "TCP_MSS: tcp maximum segment size. (default is 536, a conservative default,)"
			default 1460
		config TCP_SND_BUF
			int "TCP_SND_BUF: tcp sender buffer space (bytes)."
			default 20441
	endif
endmenu

menu "udp"
	config LWIP_UDP
		bool "turn on udp."
		default y
	if LWIP_UDP
		config DEFAULT_UDP_RECVMBOX_SIZE
			int "DEFAULT_UDP_RECVMBOX_SIZE: the mailbox size for the incoming packets on a netconn_udp."
			default 20
		menuconfig LWIP_DHCP
			bool "Enable DHCP"
			default y
			if LWIP_DHCP
			config DHCP_DOES_ARP_CHECK
				bool "DHCP_DOES_ARP_CHECK: do an arp check on the offered address."
				default y
			endif
		config LWIP_DHCPS
			bool "Enable DHCPS"
			default y
		menuconfig LWIP_DNS
			bool "Enable DNS"
			default y
			if LWIP_DNS
				config DNS_TABLE_SIZE
					int "DNS_TABLE_SIZE: dns maximum number of entries to maintain locally."
					default 4
				config DNS_MAX_NAME_LENGTH
					int "DNS_MAX_NAME_LENGTH: DNS maximum host name length supported in the name table."
					default 256
				config DNS_MAX_SERVERS
					int "DNS_MAX_SERVERS: The maximum of DNS servers"
					default 2
				config DNS_MAX_RETRIES
					int "DNS_MAX_RETRIES: DNS maximum number of retries when asking for a name, before timeout."
					default 4
				config DNS_LOCAL_HOSTLIST
					bool "DNS_LOCAL_HOSTLIST: Implements a local host-to-address list."
					default n
			endif
	endif
endmenu

